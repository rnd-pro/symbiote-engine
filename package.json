{
  "name": "symbiote-engine",
  "version": "0.3.0-alpha.11",
  "description": "Universal node-based execution engine. Domain-agnostic graph runtime.",
  "private": false,
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./browser": "./browser.js",
    "./cli": "./cli.js",
    "./contracts": "./contracts/index.js",
    "./contracts/*": "./contracts/*",
    "./FocusController.js": "./FocusController.js",
    "./Graph.js": "./Graph.js",
    "./GraphServer.js": "./GraphServer.js",
    "./packs/*": "./packs/*",
    "./package.json": "./package.json"
  },
  "bin": {
    "symbiote-engine": "cli.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js"
  },
  "files": [
    "*.js",
    "contracts/",
    "packs/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "graph",
    "nodes",
    "workflow",
    "dag",
    "automation",
    "execution-engine"
  ],
  "peerDependencies": {
    "ws": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RND-PRO/symbiote-engine.git"
  },
  "homepage": "https://github.com/RND-PRO/symbiote-engine#readme",
  "bugs": {
    "url": "https://github.com/RND-PRO/symbiote-engine/issues"
  },
  "author": "RND-PRO <nicothin@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
