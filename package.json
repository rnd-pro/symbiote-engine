{
  "name": "symbiote-engine",
  "version": "0.3.0-alpha.14",
  "description": "Run portable workflow graphs with a domain-agnostic Symbiote runtime.",
  "private": false,
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./browser": "./browser.js",
    "./cli": "./cli.js",
    "./contracts": "./contracts/index.js",
    "./contracts/*": "./contracts/*",
    "./artifacts": "./artifacts.js",
    "./FocusController.js": "./FocusController.js",
    "./Graph.js": "./Graph.js",
    "./GraphServer.js": "./GraphServer.js",
    "./provider-jobs": "./provider-jobs.js",
    "./render-cache": "./render-cache.js",
    "./render-captions": "./render-captions.js",
    "./render-finalize": "./render-finalize.js",
    "./render-lifecycle": "./render-lifecycle.js",
    "./render-proof": "./render-proof.js",
    "./render-progress": "./render-progress.js",
    "./render-workers": "./render-workers.js",
    "./render-jobs": "./render-jobs.js",
    "./render-selection": "./render-selection.js",
    "./render-segments": "./render-segments.js",
    "./render-admission": "./render-admission.js",
    "./providers/*": "./providers/*",
    "./packs/*": "./packs/*",
    "./package.json": "./package.json"
  },
  "bin": {
    "symbiote-engine": "cli.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js"
  },
  "files": [
    "*.js",
    "contracts/",
    "providers/",
    "packs/",
    "README.md",
    "llms.txt",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "graph",
    "nodes",
    "workflow",
    "dag",
    "automation",
    "execution-engine"
  ],
  "peerDependencies": {
    "ws": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RND-PRO/symbiote-engine.git"
  },
  "homepage": "https://github.com/RND-PRO/symbiote-engine#readme",
  "bugs": {
    "url": "https://github.com/RND-PRO/symbiote-engine/issues"
  },
  "author": "RND-PRO <nicothin@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
